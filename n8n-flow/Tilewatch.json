        "jsCode": "const body = $input.first().json.body;\n\nconst ax = body[0].accel_x;\nconst ay = body[0].accel_y;\nconst az = body[0].accel_z;\n\nvar rollRad  = Math.atan2(ay, az);\nvar pitchRad = Math.atan2(-ax, Math.sqrt((ay * ay) + (az * az)));\n\nvar rollDeg  = Math.round(rollRad  * (180 / Math.PI) * 100) / 100;\nvar pitchDeg = Math.round(pitchRad * (180 / Math.PI) * 100) / 100;\nvar magnitude = Math.round(Math.sqrt((ax*ax)+(ay*ay)+(az*az)) * 10000) / 10000;\n\nvar rollDir  = rollDeg  > 0 ? \"เอียงซ้าย\" : rollDeg  < 0 ? \"เอียงขวา\" : \"ตรง\";\nvar pitchDir = pitchDeg > 0 ? \"เงยขึ้น\"   : pitchDeg < 0 ? \"ก้มลง\"    : \"ตรง\";\n\nreturn [\n  {\n    json: {\n      temperature:     body[0].temperature,\n      pressure:        body[0].pressure,\n      device_id:       body[1].device_id,\n      accel_x:         ax,\n      accel_y:         ay,\n      accel_z:         az,\n      roll_deg:        rollDeg,\n      pitch_deg:       pitchDeg,\n      roll_direction:  rollDir,\n      pitch_direction: pitchDir,\n      magnitude_g:     magnitude\n    }\n  }\n];"
