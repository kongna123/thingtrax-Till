n              </tr>\n            </table>\n\n            <!-- ALERT BADGE + HEADLINE -->\n            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n              <tr>\n                <td style=\"padding:32px 32px 24px;\">\n                  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n                    <tr>\n                      <td valign=\"middle\">\n                        <table cellpadding=\"0\" cellspacing=\"0\">\n                          <tr>\n                            <td style=\"background:#d42020;border-radius:3px;padding:5px 14px;\">\n                              <span style=\"font-family:'IBM Plex Mono',monospace;font-size:11px;font-weight:600;color:#ffffff;letter-spacing:0.12em;\">● CRITICAL ALERT</span>\n                            </td>\n                          </tr>\n                        </table>\n                      </td>\n                      <td align=\"right\" valign=\"middle\">\n                        <div style=\"width:44px;height:44px;background:#fff0f0;border:1.5px solid #f5b0b0;border-radius:50%;text-align:center;line-height:44px;\">\n                          <span style=\"font-size:20px;display:inline-block;line-height:44px;\">🚨</span>\n                        </div>\n                      </td>\n                    </tr>\n                  </table>\n\n                  <div style=\"margin-top:20px;\">\n                    <h1 style=\"margin:0;font-size:36px;font-weight:700;color:#111111;line-height:1.1;letter-spacing:-0.02em;\">สถานการณ์<br><span style=\"color:#d42020;\">วิกฤต</span></h1>\n                  </div>\n                  <p style=\"margin:14px 0 0;font-size:15px;font-weight:600;color:#222222;line-height:1.7;\">{{ $json.summary }}</p>\n                </td>\n              </tr>\n            </table>\n\n            <!-- SENSOR GRID -->\n            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n              <tr>\n                <td style=\"padding:0 32px 24px;\">\n                  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #e8e8e8;border-radius:4px;overflow:hidden;\">\n\n                    <!-- Row 1 -->\n                    <tr>\n                      <td width=\"50%\" style=\"padding:16px 20px;border-bottom:1px solid #e8e8e8;border-right:1px solid #e8e8e8;background:#fafafa;\">\n                        <div style=\"font-family:'IBM Plex Mono',monospace;font-size:10px;color:#999999;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:6px;\">TEMPERATURE</div>\n                        <div style=\"font-family:'IBM Plex Mono',monospace;font-size:28px;font-weight:600;color:#111111;\">{{ $('Code in JavaScript2').item.json.temperature }}<span style=\"font-size:14px;color:#aaaaaa;font-weight:400;\">°C</span></div>\n                      </td>\n                      <td width=\"50%\" style=\"padding:16px 20px;border-bottom:1px solid #e8e8e8;background:#fafafa;\">\n                        <div style=\"font-family:'IBM Plex Mono',monospace;font-size:10px;color:#999999;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:6px;\">PRESSURE</div>\n                        <div style=\"font-family:'IBM Plex Mono',monospace;font-size:28px;font-weight:600;color:#111111;\">{{ $('Code in JavaScript2').item.json.pressure }}<span style=\"font-size:14px;color:#aaaaaa;font-weight:400;\"> hPa</span></div>\n                      </td>\n                    </tr>\n\n                    <!-- Row 2 -->\n                    <tr>\n                      <td width=\"50%\" style=\"padding:16px 20px;border-right:1px solid #e8e8e8;background:#fafafa;\">\n                        <div style=\"font-family:'IBM Plex Mono',monospace;font-size:10px;color:#999999;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:6px;\">ROLL</div>\n                        <div style=\"font-family:'IBM Plex Mono',monospace;font-size:28px;font-weight:600;color:#111111;\">{{ $('Code in JavaScript2').item.json.roll_deg }}<span style=\"font-size:14px;color:#aaaaaa;font-weight:400;\">°</span></div>\n                        <div style=\"font-family:'IBM Plex Mono',monospace;font-size:11px;color:#d42020;margin-top:4px;font-weight:600;\">{{ $('Code in JavaScript2').item.json.roll_direction }}</div>\n                      </td>\n                      <td width=\"50%\" style=\"padding:16px 20px;background:#fafafa;\">\n                        <div style=\"font-family:'IBM Plex Mono',monospace;font-size:10px;color:#999999;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:6px;\">PITCH</div>\n                        <div style=\"font-family:'IBM Plex Mono',monospace;font-size:28px;font-weight:600;color:#111111;\">{{ $('Code in JavaScript2').item.json.pitch_deg }}<span style=\"font-size:14px;color:#aaaaaa;font-weight:400;\">°</span></div>\n                        <div style=\"font-family:'IBM Plex Mono',monospace;font-size:11px;color:#d42020;margin-top:4px;font-weight:600;\">{{ $('Code in JavaScript2').item.json.pitch_direction }}</div>\n                      </td>\n                    </tr>\n\n                  </table>\n                </td>\n              </tr>\n            </table>\n\n            <!-- ACCEL ROW -->\n            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n              <tr>\n                <td style=\"padding:0 32px 24px;\">\n                  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #e8e8e8;border-radius:4px;overflow:hidden;\">\n                    <tr>\n                      <td width=\"33%\" style=\"padding:14px 16px;background:#fafafa;text-align:center;border-right:1px solid #e8e8e8;\">\n                        <div style=\"font-family:'IBM Plex Mono',monospace;font-size:10px;color:#999999;letter-spacing:0.1em;margin-bottom:6px;\">ACCEL X</div>\n                        <div style=\"font-family:'IBM Plex Mono',monospace;font-size:20px;color:#111111;font-weight:600;\">{{ $('Code in JavaScript2').item.json.accel_x }}<span style=\"font-size:11px;color:#aaaaaa;font-weight:400;\">g</span></div>\n                      </td>\n                      <td width=\"33%\" style=\"padding:14px 16px;background:#fafafa;text-align:center;border-right:1px solid #e8e8e8;\">\n                        <div style=\"font-family:'IBM Plex Mono',monospace;font-size:10px;color:#999999;letter-spacing:0.1em;margin-bottom:6px;\">ACCEL Y</div>\n                        <div style=\"font-family:'IBM Plex Mono',monospace;font-size:20px;color:#111111;font-weight:600;\">{{ $('Code in JavaScript2').item.json.accel_y }}<span style=\"font-size:11px;color:#aaaaaa;font-weight:400;\">g</span></div>\n                      </td>\n                      <td width=\"33%\" style=\"padding:14px 16px;background:#fafafa;text-align:center;\">\n                        <div style=\"font-family:'IBM Plex Mono',monospace;font-size:10px;color:#999999;letter-spacing:0.1em;margin-bottom:6px;\">ACCEL Z</div>\n                        <div style=\"font-family:'IBM Plex Mono',monospace;font-size:20px;color:#111111;font-weight:600;\">{{ $('Code in JavaScript2').item.json.accel_z }}<span style=\"font-size:11px;color:#aaaaaa;font-weight:400;\">g</span></div>\n                      </td>\n                    </tr>\n                  </table>\n                </td>\n              </tr>\n            </table>\n\n            <!-- DETAIL BOX -->\n            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n              <tr>\n                <td style=\"padding:0 32px 36px;\">\n                  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#fafafa;border:1px solid #e8e8e8;border-left:3px solid #d42020;border-radius:0 4px 4px 0;\">\n                    <tr>\n                      <td style=\"padding:20px 24px;\">\n                        <div style=\"font-family:'IBM Plex Mono',monospace;font-size:10px;color:#d42020;letter-spacing:0.12em;text-transform:uppercase;font-weight:600;margin-bottom:12px;\">ANALYSIS DETAIL</div>\n                        <div style=\"font-size:14px;color:#333333;line-height:1.9;white-space:pre-line;\">{{ $json.detail }}</div>\n                      </td>\n                    </tr>\n                  </table>\n                </td>\n              </tr>\n            </table>\n\n          </td>\n        </tr>\n\n        <!-- FOOTER -->\n        <tr>\n          <td style=\"padding:20px 0;text-align:center;\">\n            <span style=\"font-family:'IBM Plex Mono',monospace;font-size:12px;color:#aaaaaa;letter-spacing:0.1em;\">IoT DISASTER WARNING SYSTEM · AUTO-GENERATED ALERT</span>\n          </td>\n        </tr>\n\n      </table>\n    </td>\n  </tr>\n</table>\n</body>\n</html>",
